\ Выводит заголовок Portable Bitmap Format файла
функ создать_заголовок(ширина, высота)
    \ P4 - PBF, затем ширина и высота
    вывод: "P4", пс, ширина, " ", высота

\ Сопоставить пиксель к комплексному числу
функ сопоставить_пиксель_х(н, х)
    \ Преобразовать координаты пикселя в комплексное число
    хмин := -1.5
    хмакс := 0.5
    возврат хмин + (х / (н - 1)) * (хмакс - хмин)

функ сопоставить_пиксель_у(н, у)
    \ Преобразовать координаты пикселя в комплексное число
    умин := -1.0
    умакс := 1.0
    возврат умин + (у / (н - 1)) * (умакс - умин)

\ Принадлежит ли комплексное число множеству Мандельброта
функ итерирование(рац, ирац, макс_итер)
    зрац := 0.0
    зирац := 0.0

    для И от 0 до макс_итер цикл
        темп := зрац * зрац - зирац * зирац + рац
        зирац := 2.0 * зрац * зирац + ирац
        зрац := темп

        если зрац * зрац + зирац * зирац > 4.0 то
            возврат И
    возврат макс_итер

функ вход()
    ввод: н

    пока не тип_цел(н) цикл
        вывод: "Ошибка: ожидается целое число"
        ввод: н

    создать_заголовок(н, н)

    шейдеры := <* " ", "░", "▒", "▓", "█" *>

    \ Рисование множества Мандельброта
    для Иу от 0 до н цикл
        линия := ""
        рац := сопоставить_пиксель_у(н, Иу)
        для Иx от 0 до н цикл
            ирац := сопоставить_пиксель_х(н, Иx)
            итер := итерирование(ирац, рац, 1000)
            индекс_шейдера := итер * (#шейдеры - 1) / 1000
            линия := линия + шейдеры[индекс_шейдера]
        вывод: линия

вход()
