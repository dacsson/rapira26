\ Tests: all тип_* functions (return да or нет)
\ No input required.

\ --- тип_пуст ---
вывод: тип_пуст(пусто)
\ => да
вывод: тип_пуст(0)
\ => нет

\ --- тип_лог ---
вывод: тип_лог(да)
\ => да
вывод: тип_лог(нет)
\ => да
вывод: тип_лог(1)
\ => нет

\ --- тип_цел ---
вывод: тип_цел(42)
\ => да
вывод: тип_цел(-7)
\ => да
вывод: тип_цел(3.14)
\ => нет
вывод: тип_цел("42")
\ => нет

\ --- тип_вещ ---
вывод: тип_вещ(3.14)
\ => да
вывод: тип_вещ(1.9е-8)
\ => да
вывод: тип_вещ(42)
\ => нет

\ --- тип_текст ---
вывод: тип_текст("hello")
\ => да
вывод: тип_текст("")
\ => да
вывод: тип_текст(42)
\ => нет

\ --- тип_корт ---
вывод: тип_корт(( 1, 2 ))
\ => да
вывод: тип_корт(( ))
\ => да
вывод: тип_корт("текст")
\ => нет

\ --- тип_проц and тип_функ ---
проц МОЯ_ПРОЦ ()
  возврат

функ МОЯ_ФУНК ()
  возврат 1

вывод: тип_проц(МОЯ_ПРОЦ)
\ => да
вывод: тип_функ(МОЯ_ФУНК)
\ => да
вывод: тип_проц(МОЯ_ФУНК)
\ => нет
вывод: тип_функ(МОЯ_ПРОЦ)
\ => нет

\ --- type-based dispatch with выбор ---
функ ТИП_СТРОКОЙ (X)
  выбор
    при тип_пуст(X):   возврат "пусто"
    при тип_лог(X):    возврат "логический"
    при тип_цел(X):    возврат "целый"
    при тип_вещ(X):    возврат "вещественный"
    при тип_текст(X):  возврат "текст"
    при тип_корт(X):   возврат "кортеж"
    при тип_проц(X):   возврат "процедура"
    при тип_функ(X):   возврат "функция"

вывод: ТИП_СТРОКОЙ(пусто)
\ => пусто
вывод: ТИП_СТРОКОЙ(да)
\ => логический
вывод: ТИП_СТРОКОЙ(42)
\ => целый
вывод: ТИП_СТРОКОЙ(3.14)
\ => вещественный
вывод: ТИП_СТРОКОЙ("hi")
\ => текст
вывод: ТИП_СТРОКОЙ(( 1, ))
\ => кортеж
