\ Tests: all four loop forms and выход (break)
\ No input required.

\ --- infinite loop with выход ---
I := 1
цикл
  если I > 3 то выход все
  вывод: I
  I := I + 1
кц
\ => 1
\ => 2
\ => 3

\ --- пока (while pre-condition) ---
N := 5
пока N > 0 цикл
  вывод бпс: N, " "
  N := N - 1
кц
вывод: ""
\ => 5 4 3 2 1

\ --- кц по (post-condition: also exit when condition is true) ---
\ loop body always runs at least once, exits when СТОП = да
СТОП := нет
K := 0
пока не СТОП цикл
  K := K + 1
  если K >= 3 то СТОП := да все
кц по СТОП
вывод: K
\ => 3

\ --- повтор N (repeat N times) ---
повтор 4 цикл
  вывод бпс: "* "
кц
вывод: ""
\ => * * * *

\ --- повтор 0 (body never executes) ---
повтор 0 цикл
  вывод: "никогда"
кц
\ => (no output)

\ --- для от до (for i from a to b, step 1) ---
для I от 1 до 5 цикл
  вывод бпс: I, " "
кц
вывод: ""
\ => 1 2 3 4 5

\ --- для шаг (for with explicit step) ---
для I от 10 до 2 шаг -2 цикл
  вывод бпс: I, " "
кц
вывод: ""
\ => 10 8 6 4 2

\ --- для without от (start defaults to 1) ---
для I шаг 1 цикл
  вывод бпс: I, " "
  если I >= 3 то выход все
кц
вывод: ""
\ => 1 2 3

\ --- для от a до b with empty range (a > b, positive step) → body never runs ---
для I от 5 до 3 цикл
  вывод: "никогда"
кц
\ => (no output)

\ --- для пока: for loop with an additional while-condition ---
для I от 1 до 100
  пока I * I < 50 цикл
  вывод бпс: I, " "
кц
вывод: ""
\ => 1 2 3 4 5 6 7   (7*7=49 < 50, 8*8=64 >= 50)

\ --- выход inside nested loops exits only the innermost loop ---
для I от 1 до 3 цикл
  для J от 1 до 3 цикл
    если J = 2 то выход все
    вывод бпс: I, ",", J, " "
  кц
кц
вывод: ""
\ => 1,1 2,1 3,1
