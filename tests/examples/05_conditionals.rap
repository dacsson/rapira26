\ Tests: если/то/иначе, выбор
\ No input required.

\ --- basic if-then ---
если 3 > 2 то
  вывод: "да, 3 больше 2"
\ => да, 3 больше 2

\ --- if-then-else ---
если 1 > 2 то
  вывод: "никогда"
иначе
  вывод: "иначе-ветка"
\ => иначе-ветка

\ --- nested if ---
X := 5
если X > 0 то
  если X > 10 то
    вывод: "большое"
  иначе
    вывод: "маленькое положительное"
иначе
  вывод: "неположительное"
\ => маленькое положительное

\ --- пусто is falsy: только да is truthy, всё остальное вызывает ошибку в условии ---
\ (Note: conditions must be logical objects. Using non-logical in если is a runtime error.)
если пусто = пусто то
  вывод: "пусто равно пусто"
\ => пусто равно пусто

\ --- chained: compute sign with nested if ---
функ ЗНАК (N)
  если N > 0 то
    возврат 1
  иначе если N < 0 то
    возврат -1
  иначе
    возврат 0

вывод: ЗНАК(5)
\ => 1
вывод: ЗНАК(-3)
\ => -1
вывод: ЗНАК(0)
\ => 0

проц цепочка(н, м)
    если н = 1 и м = 0 то
        вывод: "1"
    иначе если м = 1 то
        вывод: "1 и 1"
    иначе если м = 2 то
        вывод: "1 и 2"

цепочка(1, 2)
\ => 1 и 2

функ вход()
    вывод: "Конец теста"
\ => Конец теста
