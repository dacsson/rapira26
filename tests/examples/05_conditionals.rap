\ Tests: если/то/иначе/все, выбор (both forms)
\ No input required.

\ --- basic if-then ---
если 3 > 2 то
  вывод: "да, 3 больше 2"
все
\ => да, 3 больше 2

\ --- if-then-else ---
если 1 > 2 то
  вывод: "никогда"
иначе
  вывод: "иначе-ветка"
все
\ => иначе-ветка

\ --- nested if ---
X := 5
если X > 0 то
  если X > 10 то
    вывод: "большое"
  иначе
    вывод: "маленькое положительное"
  все
иначе
  вывод: "неположительное"
все
\ => маленькое положительное

\ --- выбор form 1: switch on a value ---
ДЕНЬ := "ср"
выбор ДЕНЬ
  при "пн", "вт", "ср", "чт", "пт":
    вывод: "будний"
  при "сб", "вс":
    вывод: "выходной"
  иначе
    вывод: "неизвестный"
все
\ => будний

\ --- выбор form 1: иначе branch when no match ---
выбор 42
  при 1: вывод: "один"
  при 2: вывод: "два"
  иначе  вывод: "что-то другое"
все
\ => что-то другое

\ --- выбор form 1: no иначе, no match → nothing happens ---
выбор 99
  при 1: вывод: "один"
  при 2: вывод: "два"
все
\ => (no output)

\ --- выбор form 2: select first true condition ---
N := -3
выбор
  при N > 0:  вывод: "положительное"
  при N < 0:  вывод: "отрицательное"
  иначе       вывод: "ноль"
все
\ => отрицательное

\ --- выбор form 2: only first true branch executes ---
выбор
  при да:    вывод: "первое"
  при да:    вывод: "второе (не выполнится)"
все
\ => первое

\ --- пусто is falsy: только да is truthy, всё остальное вызывает ошибку в условии ---
\ (Note: conditions must be logical objects. Using non-logical in если is a runtime error.)
если пусто = пусто то
  вывод: "пусто равно пусто"
все
\ => пусто равно пусто

\ --- chained: compute sign with nested if ---
функ ЗНАК (N)
  если N > 0 то
    возврат 1
  иначе
    если N < 0 то
      возврат -1
    иначе
      возврат 0
    все
  все
конец

вывод: ЗНАК(5)
\ => 1
вывод: ЗНАК(-3)
\ => -1
вывод: ЗНАК(0)
\ => 0
