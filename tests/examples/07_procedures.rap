\ Tests: procedure definition, call, input parameters, early return (возврат)
\ No input required.

\ --- simplest procedure ---
проц ПРИВЕТСТВИЕ ()
  вывод: "Привет!"

вызов ПРИВЕТСТВИЕ()
\ => Привет!

\ --- procedure with input parameter ---
проц ПЕЧАТЬ_КВАДРАТА (N)
  вывод: N * N

вызов ПЕЧАТЬ_КВАДРАТА(5)
\ => 25
вызов ПЕЧАТЬ_КВАДРАТА(-3)
\ => 9

\ --- by default paramter in just input
проц С_СТРЕЛКОЙ (X)
  вывод: X + 1

вызов С_СТРЕЛКОЙ(10)
\ => 11

\ --- multiple parameters ---
проц СУММА_И_ПРОИЗВЕДЕНИЕ (A, B)
  вывод: "сумма: ", A + B
  вывод: "произведение: ", A * B

вызов СУММА_И_ПРОИЗВЕДЕНИЕ(3, 4)
\ => сумма: 7
\ => произведение: 12

\ --- early return (возврат without value) ---
проц ТОЛЬКО_ПОЛОЖИТЕЛЬНЫЕ (N)
  если N <= 0 то возврат
  вывод: N

вызов ТОЛЬКО_ПОЛОЖИТЕЛЬНЫЕ(5)
\ => 5
вызов ТОЛЬКО_ПОЛОЖИТЕЛЬНЫЕ(-3)
\ => (no output)
вызов ТОЛЬКО_ПОЛОЖИТЕЛЬНЫЕ(0)
\ => (no output)

\ --- print frame N×N (from spec §1, example 2) ---
проц РАМКА (N)
  вывод: "@" * N
  повтор N-2 цикл
    вывод: "@" + " " * (N-2) + "@"
  вывод: "@" * N

вызов РАМКА(5)
\ => @@@@@
\ => @   @
\ => @   @
\ => @   @
\ => @@@@@

вызов РАМКА(3)
\ => @@@
\ => @ @
\ => @@@

\ --- procedures as values: assign procedure to variable, call through it ---
проц ДВА_ИКСА (X)
  вывод: X * 2

ДЕЙСТВИЕ := ДВА_ИКСА
вызов ДЕЙСТВИЕ(7)
\ => 14

\ --- implicit call without вызов (spec §2.2.4.2) ---
ПРИВЕТСТВИЕ()
\ => Привет!
ПЕЧАТЬ_КВАДРАТА(6)
\ => 36
