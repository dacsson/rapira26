\ Tests: <= (return/in-out parameters)
\ No input required.
\ A parameter marked <= is passed by reference: changes inside the
\ procedure are visible to the caller after the call.

\ --- basic in-out parameter ---
проц УДВОИТЬ (<=X)
  X := X * 2
конец

А := 5
вызов УДВОИТЬ(<=А)
вывод: А
\ => 10

\ --- multiple return parameters ---
проц SWAP (<=A, <=B)
  свои: TEMP
  TEMP := A
  A := B
  B := TEMP
конец

P := 3; Q := 7
вызов SWAP(<=P, <=Q)
вывод: P, " ", Q
\ => 7 3

\ --- mix of input and return parameters (spec §1.5, example 9) ---
проц ЗАМЕНА (<=ГДЕ, =>ЧТО, =>НА_ЧТО)
  N := 1
  цикл
    K := индекс(ЧТО, ГДЕ[N:])
    если K = 0 то выход все
    K := N + K - 1
    ГДЕ[K : K + #ЧТО - 1] := НА_ЧТО
    N := K + #НА_ЧТО
  кц
конец

ТЕКСТ := "Знайка и Знайка"
вызов ЗАМЕНА(<=ТЕКСТ, =>"Знайка", =>"Незнайка")
вывод: ТЕКСТ
\ => Незнайка и Незнайка

\ --- sorting via return parameter (from spec §1, example 6) ---
проц СОРТИРОВКА (<=ЧИСЛА)
  свои: НОВ, МИН, ИНД, К
  НОВ := <* *>
  пока ЧИСЛА /= <* *> цикл
    МИН := ЧИСЛА[1]; ИНД := 1
    для К от 2 до #ЧИСЛА цикл
      если ЧИСЛА[К] < МИН то
        МИН := ЧИСЛА[К]; ИНД := К
      все
    кц
    НОВ := НОВ + <* МИН *>
    ЧИСЛА[ИНД:ИНД] := <* *>       \ delete element at ИНД
  кц
  ЧИСЛА := НОВ
конец

ДАННЫЕ := <* 5, 1, 4, 2, 3 *>
вызов СОРТИРОВКА(<=ДАННЫЕ)
вывод: ДАННЫЕ
\ => <* 1, 2, 3, 4, 5 *>

\ --- return parameter of tuple type: append to caller's list ---
проц ДОБАВИТЬ (<=СПИСОК, =>ЭЛЕМЕНТ)
  СПИСОК := СПИСОК + <* ЭЛЕМЕНТ *>
конец

МОЙ_СПИСОК := <* *>
вызов ДОБАВИТЬ(<=МОЙ_СПИСОК, =>"первый")
вызов ДОБАВИТЬ(<=МОЙ_СПИСОК, =>"второй")
вызов ДОБАВИТЬ(<=МОЙ_СПИСОК, =>"третий")
вывод: МОЙ_СПИСОК
\ => <* первый, второй, третий *>
