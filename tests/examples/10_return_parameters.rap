\ Tests: вых  (return/in-out parameters)
\ No input required.
\ A parameter marked вых  is passed by reference: changes inside the
\ procedure are visible to the caller after the call.
\ It is forbidden to pass return parameter from top level.

\ --- basic in-out parameter ---
проц УДВОИТЬ (вых X)
  X := X * 2

проц чек()
    А := 5
    вызов УДВОИТЬ(вых А)
    вывод: А

чек()
\ => 10

\ --- multiple return parameters ---
проц SWAP (вых A, вых B)
  свои: TEMP
  TEMP := A
  A := B
  B := TEMP

проц ЧЕК1()
  P := 3
  Q := 7
  вызов SWAP(вых P, вых Q)
  вывод: P, " ", Q

ЧЕК1()
\ => 7 3

\ --- mix of input and return parameters (spec §1.5, example 9) ---
проц ЗАМЕНА (вых ГДЕ, ЧТО, НА_ЧТО)
  N := 0
  цикл
    K := индекс(ЧТО, ГДЕ[N:])
    если K = -1 то выход
    K := N + K
    ГДЕ[K : K + #ЧТО] := НА_ЧТО
    N := K + #НА_ЧТО

проц ЧЕК2()
  ТЕКСТ := "Знайка и Знайка"
  вызов ЗАМЕНА(вых ТЕКСТ, "Знайка", "Незнайка")
  вывод: ТЕКСТ

ЧЕК2()
\ => Незнайка и Незнайка

\ --- sorting via return parameter (from spec §1, example 6) ---
проц СОРТИРОВКА (вых ЧИСЛА)
  свои: НОВ, МИН, ИНД, К
  НОВ := ( )
  пока ЧИСЛА /= ( ) цикл
    МИН := ЧИСЛА[0]
    ИНД := 0
    для К от 1 до #ЧИСЛА - 1 цикл
      если ЧИСЛА[К] < МИН то
        МИН := ЧИСЛА[К]
        ИНД := К
    НОВ := НОВ + ( МИН, )
    ЧИСЛА[ИНД:ИНД] := ( )       \ delete element at ИНД
  ЧИСЛА := НОВ

проц ЧЕК3()
    ДАННЫЕ := ( 5, 1, 4, 2, 3 )
    вызов СОРТИРОВКА(вых ДАННЫЕ)
    вывод: ДАННЫЕ

ЧЕК3()
\ => ( 1, 2, 3, 4, 5 )

\ --- return parameter of tuple type: append to caller's list ---
проц ДОБАВИТЬ (вых СПИСОК, ЭЛЕМЕНТ)
  СПИСОК := СПИСОК + ( ЭЛЕМЕНТ, )

проц ЧЕК4()
  МОЙ_СПИСОК := ( )
  вызов ДОБАВИТЬ(вых МОЙ_СПИСОК, "первый")
  вызов ДОБАВИТЬ(вых МОЙ_СПИСОК, "второй")
  вызов ДОБАВИТЬ(вых МОЙ_СПИСОК, "третий")
  вывод: МОЙ_СПИСОК

ЧЕК4()
\ => ( первый, второй, третий )
