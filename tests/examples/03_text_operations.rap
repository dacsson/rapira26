\ Tests: text operations — length, index, concat, repeat, slice, subscript assign
\ No input required.

Т := "огурец"       \ length 6, 0-indexed

\ --- length ---
вывод: #Т
\ => 6
вывод: #""
\ => 0

\ --- indexing (0-based, see PHASE1_DIFFERENCE.md) ---
вывод: Т[0]
\ => о
вывод: Т[2]
\ => у
вывод: Т[5]
\ => ц

\ --- slicing (0-based) ---
вывод: Т[1:4]
\ => гур
вывод: Т[3:]
\ => рец
вывод: Т[:3]
\ => огу
вывод: Т[:]
\ => огурец

\ --- from spec (p.5): "аб вг д"
АБ := "аб вг д"
вывод: АБ[3:]
\ => вг д
вывод: АБ[3:5]
\ => вг

\ --- concat ---
вывод: "аб" + "вг"
\ => абвг
вывод: "привет" + " " + "мир"
\ => привет мир

\ --- repeat (text * non-negative integer) ---
вывод: "аб" * 3
\ => абабаб
вывод: "х" * 0
\ => (empty line)
вывод: 3 * "аб"
\ => абабаб
\ (order can be either way per spec)

\ --- concat builds reversed string ---
НАОБОРОТ := ""
Т2 := "abcd"
для К от 0 до #Т2 - 1 цикл
  НАОБОРОТ := Т2[К] + НАОБОРОТ
вывод: НАОБОРОТ
\ => dcba

\ --- subscript assignment ---
С := "hello"
С[0] := "H"
вывод: С
\ => Hello

\ --- slice assignment (replaces the slice) ---
С[1:3] := "EL"
вывод: С
\ => HELlo

\ --- equality ---
вывод: "abc" = "abc"
\ => да
вывод: "abc" = "ABC"
\ => нет
вывод: "" = ""
\ => да

\ --- индекс: first occurrence of substring in text (0-based, -1 if not found) ---
вывод: индекс("вг", "аб вг д")
\ => 3
вывод: индекс("х", "аб вг д")
\ => -1
вывод: индекс("", "abc")
\ => 0

функ вход()
    вывод: "Конец теста"
\ => Конец теста
