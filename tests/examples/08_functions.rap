\ Tests: function definition, return value, recursion
\ No input required.

\ --- simplest function ---
функ ОДИН ()
  возврат 1
конец

вывод: ОДИН()
\ => 1

\ --- function with parameter ---
функ КВАДРАТ (N)
  возврат N * N
конец

вывод: КВАДРАТ(7)
\ => 49
вывод: КВАДРАТ(-4)
\ => 16

\ --- function used inside expression ---
вывод: КВАДРАТ(3) + КВАДРАТ(4)
\ => 25

\ --- early return (возврат with value) ---
функ АБС (X)
  если X >= 0 то
    возврат X
  иначе
    возврат -X
  все
конец

вывод: АБС(-5)
\ => 5
вывод: АБС(3)
\ => 3
вывод: АБС(0)
\ => 0

\ --- primality test (from spec §1, example 1) ---
функ ПРОСТОЕ (N)
  если N < 2 то
    возврат нет
  все
  для M от 2 до корень(N) + 0.5 цикл
    если N /% M = 0 то
      возврат нет
    все
  кц
  возврат да
конец

вывод: ПРОСТОЕ(2)
\ => да
вывод: ПРОСТОЕ(3)
\ => да
вывод: ПРОСТОЕ(4)
\ => нет
вывод: ПРОСТОЕ(17)
\ => да
вывод: ПРОСТОЕ(2003)
\ => да
вывод: ПРОСТОЕ(2004)
\ => нет

\ --- recursive function: factorial ---
функ ФАКТ (N)
  если N <= 1 то
    возврат 1
  иначе
    возврат N * ФАКТ(N - 1)
  все
конец

вывод: ФАКТ(0)
\ => 1
вывод: ФАКТ(1)
\ => 1
вывод: ФАКТ(5)
\ => 120
вывод: ФАКТ(10)
\ => 3628800

\ --- recursive function: fibonacci ---
функ ФИБ (N)
  если N <= 1 то
    возврат N
  иначе
    возврат ФИБ(N-1) + ФИБ(N-2)
  все
конец

вывод: ФИБ(0)
\ => 0
вывод: ФИБ(1)
\ => 1
вывод: ФИБ(6)
\ => 8
вывод: ФИБ(10)
\ => 55

\ --- function returning a tuple ---
функ ДИАПАЗОН (A, B)
  РЕЗУЛЬТАТ := <* *>
  для I от A до B цикл
    РЕЗУЛЬТАТ := РЕЗУЛЬТАТ + <* I *>
  кц
  возврат РЕЗУЛЬТАТ
конец

вывод: ДИАПАЗОН(1, 5)
\ => <* 1, 2, 3, 4, 5 *>
вывод: ДИАПАЗОН(3, 3)
\ => <* 3 *>
вывод: ДИАПАЗОН(5, 3)
\ => <* *>            (empty: start > end)
