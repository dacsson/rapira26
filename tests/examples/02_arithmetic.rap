\ Tests: arithmetic operators, precedence, mixed int/real
\ No input required.

\ --- basic arithmetic ---
вывод: 2 + 3
\ => 5
вывод: 10 - 4
\ => 6
вывод: 3 * 4
\ => 12
вывод: -5
\ => -5
вывод: +3
\ => 3

\ --- power ---
вывод: 2 ** 10
\ => 1024
вывод: 2 ** 0
\ => 1
вывод: 9 ** 0.5
\ => 3.0

\ --- integer division and remainder (integers only, divisor must be > 0) ---
вывод: 7 // 2
\ => 3
вывод: -7 // 2
\ => -4        (floor division: spec defines via subtraction loop)
вывод: 7 /% 2
\ => 1
вывод: -7 /% 2
\ => 1         (defined as A - A//B*B)

\ --- real division ---
вывод: 7.0 / 2
\ => 3.5
вывод: 1.0 / 3.0
\ => 0.3333333333333333   (implementation-defined precision)

\ --- int / int: result is integer if exact, real otherwise (spec §2.2.4.2) ---
вывод: 6 / 2
\ => 3
вывод: 7 / 2
\ => 3.5

\ --- comparisons (return да or нет) ---
вывод: 3 > 2
\ => да
вывод: 3 < 2
\ => нет
вывод: 3 >= 3
\ => да
вывод: 3 <= 2
\ => нет
вывод: 3 = 3
\ => да
вывод: 3 /= 4
\ => да

\ --- boolean operators (short-circuit evaluation) ---
вывод: да и нет
\ => нет
вывод: да или нет
\ => да
вывод: не да
\ => нет
вывод: не нет
\ => да

\ --- precedence: ** before *, * before +, unary before binary ---
вывод: 2 + 3 * 4
\ => 14
вывод: 2 ** 3 * 4
\ => 32
вывод: -2 ** 2
\ => -4           (unary - same precedence as binary, left-to-right: -(2**2)? or (-2)**2?)
                  \ spec says unary +/- same level as binary +/-, LOWER than **
                  \ so: -(2**2) = -4
вывод: 2 + 3 > 4
\ => да
вывод: не 3 > 4
\ => да            (не has lower precedence than > -- wait, spec says не < =, so: не (3>4) = да)

\ --- standard math functions ---
вывод: abs(-7)
\ => 7
вывод: abs(3)
\ => 3
вывод: sign(-5)
\ => -1
вывод: sign(0)
\ => 0
вывод: sign(3)
\ => 1
вывод: корень(9)
\ => 3.0
вывод: целч(5.9)
\ => 5
вывод: целч(-5.9)
\ => -6
вывод: окрч(5.4)
\ => 5
вывод: окрч(5.7)
\ => 6
вывод: окрч(-5.4)
\ => -5
вывод: окрч(-5.7)
\ => -6
