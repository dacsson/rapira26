\ Tests: чужие (foreign names), свои (own names), dynamic scoping
\ No input required.
\ Key rule: any non-local name used inside a procedure must be listed
\ in чужие: — otherwise it is treated as a fresh local name (= пусто).

\ --- basic: чужие allows reading a caller's variable ---
проц ПЕЧАТАЕТ_ВНЕШНЕЕ ()
  чужие: ЗНАЧЕНИЕ
  вывод: ЗНАЧЕНИЕ

проц чек1()
    ЗНАЧЕНИЕ := 42
    вызов ПЕЧАТАЕТ_ВНЕШНЕЕ()

чек1()
\ => 42

\ --- without чужие: the name is local, defaults to пусто ---
проц БЕЗ_ЧУЖИХ ()
  вывод: ЗНАЧЕНИЕ          \ ЗНАЧЕНИЕ here is a fresh local, not the outer one

вызов БЕЗ_ЧУЖИХ()
\ => пусто

\ --- чужие allows writing to caller's variable ---
проц УДВАИВАЕТ ()
  чужие: X
  X := X * 2

\ чужие usage from top-level is forbidden
проц ЧУЖ()
  X := 5
  вызов УДВАИВАЕТ()
  возврат X

X := 0
вывод: ЧУЖ()
\ => 10
вывод: X
\ => 0
\ top-level X is not affected, forbidden usage of foreign args

\ --- dynamic (not lexical): lookup goes up the call chain ---
\ ВНЕШНЯЯ sets СЧЁТЧИК, calls СРЕДНЯЯ, which calls ВНУТРЕННЯЯ.
\ ВНУТРЕННЯЯ declares СЧЁТЧИК in чужие: and finds it in ВНЕШНЯЯ's frame.

проц ВНУТРЕННЯЯ ()
  чужие: СЧЁТЧИК
  СЧЁТЧИК := СЧЁТЧИК + 100

проц СРЕДНЯЯ ()
  вызов ВНУТРЕННЯЯ()        \ СРЕДНЯЯ has no СЧЁТЧИК, call goes further up

проц ВНЕШНЯЯ ()
  свои: СЧЁТЧИК
  СЧЁТЧИК := 1
  вызов СРЕДНЯЯ()
  вывод: СЧЁТЧИК

вызов ВНЕШНЯЯ()
\ => 101

\ --- свои declares a fresh local, hiding any outer variable of same name ---
проц С_ЛОКАЛЬНЫМ ()
  свои: X
  X := 999
  вывод: "локальный X = ", X

X := 77
вызов С_ЛОКАЛЬНЫМ()
вывод: "внешний X = ", X    \ X unchanged because С_ЛОКАЛЬНЫМ's X is local
\ => локальный X = 999
\ => внешний X = 77

\ --- procedure name is local within itself (for recursion without чужие) ---
\ (spec §2.2.2: procedure/function name is local inside itself)
функ РЕКУРС (N)
  если N <= 0 то возврат 0
  возврат 1 + РЕКУРС(N - 1)

вывод: РЕКУРС(5)
\ => 5
