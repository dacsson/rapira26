\ Types hold variants
тип Сезон
    Зима
    Весна
    Лето
    Осень

\ Of course we can pattern match
проц сезон_в_строку(сезон)
    выбор сейчас
        при Зима: вывод: "Зима"
        при Весна: вывод: "Весна"
        при Лето: вывод: "Лето"
        при Осень: вывод: "Осень"

сейчас := Лето
вывод: сезон_в_строку(сейчас)
\ => Лето

\ Variants on themselfs can hold fields
тип ШкольныйЧел
    Ученик(класс, имя)
    Учитель(имя)

функ кто_в_школе(чел)
    выбор чел
        при Ученик(класс, имя):
            вывод: "в классе ученик: ", имя
        при Учитель(имя):
            вывод: "в классе учитель: ", имя

чел := Ученик("Тёма", 11)
вывод: кто_в_школе(чел)
\ => в классе ученик: Тёма

\ This is how we create JUST structs
тип Точка
    Точка(х, у)

\ Structs are essentially "named-tuples"
точечка := Точка(2, 3)
вывод: "(х: ", точечка.х, ", у: ", точечка.у, ")"
\ => ( х: 2, у: 3 )

\ Equality of Structs
вторая := Точка(2, 3)
вывод: точечка = вторая
\ => да

\ Mutation
точечка.х := 3
вывод: "(х: ", точечка.х, ", у: ", точечка.у, ")"
\ => ( х: 3, у: 3 )
