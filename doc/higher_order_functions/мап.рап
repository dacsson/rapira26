функ мап(лист, ф)
  вывод: "лист: ", лист
  если длин(лист) = 0 то
    \ пустой кортеж
    возврат ()
  иначе
    \ (<expr>,) - кортеж из одного элемента
    \ (<expr>) - выражение в скобках,
    \ поэтому ставим запятую в левой части
    \ `+` - конкатенация кортежей
    \ `[1:]` - аля list.tail, только создаёт slice 
    возврат (ф(лист[0]),) + мап(лист[1:], ф)

функ удвоить(х)
  возврат х * 2

\ ли := (1, 2, 3, 4)
\ вывод: мап(ли, удвоить)		

\ вывод будет вот такой:
\ лист: ( 1, 2, 3, 4 )
\ лист: ( 2, 3, 4 )
\ лист: ( 3, 4 )
\ лист: ( 4 )
\ лист: ( )
\ ( 2, 4, 6, 8 )	






